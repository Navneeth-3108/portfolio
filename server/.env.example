PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/portfolio_db
NODE_ENV=development

# Email Configuration (Resend)
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=Portfolio Contact <onboarding@resend.dev>

# One or more comma-separated recipients
CONTACT_NOTIFY_EMAIL=your-receiving-email@example.com

# Admin Credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_secure_password
JWT_SECRET=your_jwt_secret_here

# Cloudinary (REQUIRED for project image uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Deployment
SERVER_URL=http://localhost:5000
# In production, this can be a comma-separated list, for example:
# https://your-app.vercel.app,https://your-app-git-main-yourname.vercel.app
CLIENT_URL=http://localhost:5173